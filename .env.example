# ─── LLM (OpenAI-compatible local server: vLLM / llama.cpp / sglang) ────────
# Defaults match the vLLM-served Qwen3.5-2B at /home/changqing/workspace/model_deploy
BANBU_LLM_BASE_URL=http://localhost:30000/v1
BANBU_LLM_MODEL=qwen3.5-2b
BANBU_LLM_API_KEY=EMPTY
BANBU_LLM_TEMPERATURE=0.0
BANBU_LLM_MAX_TOKENS=1024
BANBU_LLM_TIMEOUT_SECONDS=60
BANBU_LLM_TOOLCALL_MODE=auto

# ─── Device platform ─────────────────────────────────────
BANBU_IOT_BASE_URL=http://192.168.1.78:8000
BANBU_IOT_TIMEOUT_SECONDS=10

# ─── This service ────────────────────────────────────────
BANBU_HOST=0.0.0.0
BANBU_PORT=9000
BANBU_WEBHOOK_PATH=/api/v2/events/batch

# ─── IM reactive entry channels ──────────────────────────
BANBU_IM_ENABLED=false
BANBU_IM_FEISHU_ENABLED=false
BANBU_IM_FEISHU_VERIFICATION_TOKEN=
BANBU_IM_FEISHU_ENCRYPT_KEY=
BANBU_IM_FEISHU_APP_ID=
BANBU_IM_FEISHU_APP_SECRET=
BANBU_IM_FEISHU_API_BASE_URL=https://open.feishu.cn
BANBU_IM_FEISHU_REPLY_ENABLED=false
BANBU_IM_FEISHU_EVENT_DEDUPE_TTL_SECONDS=300
BANBU_IM_WEIXIN_ENABLED=false
BANBU_IM_WEIXIN_PATH=/api/v1/im/weixin/messages
BANBU_IM_WEIXIN_BRIDGE_TOKEN=
BANBU_IM_WEIXIN_REPLY_URL=
BANBU_IM_WEIXIN_REPLY_TIMEOUT_SECONDS=10

# ─── Vision trigger producer ─────────────────────────────
BANBU_VISION_ENABLED=false
BANBU_VISION_RTSP_URL=
BANBU_VISION_DEVICE_ID=entry_camera_vision_1
BANBU_VISION_POST_BASE_URL=http://127.0.0.1:9000
BANBU_VISION_VLM_BASE_URL=http://localhost:30000/v1
BANBU_VISION_VLM_MODEL=local-vision-model
BANBU_VISION_VLM_API_KEY=EMPTY
BANBU_VISION_VLM_TIMEOUT_SECONDS=60
BANBU_VISION_FRAME_INTERVAL_SECONDS=0.12
BANBU_VISION_JPEG_QUALITY=85
BANBU_VISION_RECONNECT_SECONDS=5.0
BANBU_VISION_MOTION_SAMPLE_SIZE=32
BANBU_VISION_MOTION_PIXEL_DIFF_THRESHOLD=18
BANBU_VISION_MOTION_CHANGED_RATIO_THRESHOLD=0.03

# ─── ContextPilot ────────────────────────────────────────
BANBU_CP_USE_GPU=false
# CONTEXTPILOT_INDEX_URL=http://localhost:8765

# ─── Runtime ─────────────────────────────────────────────
BANBU_HOME_ID=home_default
BANBU_FALLBACK_POLL_SECONDS=30
BANBU_LOG_LEVEL=INFO
BANBU_DB_PATH=./data/banbu.sqlite
BANBU_DEVICES_FILE=./banbu/config/devices.yaml
BANBU_SCENES_DIR=./banbu/config/scenes
